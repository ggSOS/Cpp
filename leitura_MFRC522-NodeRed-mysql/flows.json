        "id": "sql_insert_rfid",
        "type": "function",
        "z": "f3ce39fc1d715f7b",
        "name": "SQL INSERT RFID",
        "func": "let data = JSON.parse(msg.payload);\n\nlet uid = String(data.uid);\nlet status = String(data.status);\n\nmsg.topic = \"INSERT INTO acessos (uid, status) VALUES (?, ?)\";\n\nmsg.payload = [uid, status];\n\nreturn msg;",
